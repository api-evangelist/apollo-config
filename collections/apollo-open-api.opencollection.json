                "name": "env",
                "value": "",
                "type": "path",
                "description": "Environment (e.g., DEV, FAT, UAT, PRO)"
              },
              {
                "name": "appId",
                "value": "",
                "type": "path",
                "description": "Application ID"
              },
              {
                "name": "clusterName",
                "value": "",
                "type": "path",
                "description": "Cluster name (default is 'default')"
              },
              {
                "name": "namespaceName",
                "value": "",
                "type": "path",
                "description": "Namespace name (default is 'application')"
              },
              {
                "name": "key",
                "value": "",
                "type": "path"
              },
              {
                "name": "createIfNotExists",
                "value": "",
