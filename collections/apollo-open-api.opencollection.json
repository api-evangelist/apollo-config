          "http": {
            "method": "GET",
            "url": "http://localhost:8070/openapi/v1/envs/:env/apps/:appId/clusters/:clusterName/namespaces/:namespaceName/items",
            "params": [
              {
                "name": "env",
                "value": "",
                "type": "path",
                "description": "Environment (e.g., DEV, FAT, UAT, PRO)"
