              {
                "name": "clusterName",
                "value": "",
                "type": "path",
                "description": "Cluster name (default is 'default')"
              },
              {
                "name": "namespaceName",
                "value": "",
                "type": "path",
                "description": "Namespace name (default is 'application')"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new key-value configuration item in a namespace."
        },
        {
          "info": {
            "name": "Get a configuration item",
            "type": "http"
